---
// Agenda.astro

const agendaItems = [
  { time: "10:00 - 10:30", event: "Registration & Welcome Refreshments", isBreak: false },
  { time: "10:30 - 10:45", event: "Opening Remarks", isBreak: false },
  { time: "10:45 - 11:15", event: "Vonage Global RCS Market Update", isBreak: false },
  { time: "11:15 - 12:00", event: "Singtel Keynote: RCS Innovation in APAC", isBreak: false },
  { time: "11:45 - 12:00", event: "Coffee Break", isBreak: true },
  { time: "12:00 - 12:45", event: "Vonage Live RCS Demo", isBreak: false },
  { time: "12:45 - 13:15", event: "Q&A", isBreak: false },
  { time: "13:15 - 15:00", event: "Lunch & Networking", isBreak: true },
];
---

<div class="w-full mx-auto my-6 bg-white rounded-2xl overflow-hidden">
  <div class="overflow-hidden">    
    <!-- Agenda rows -->
    {
      agendaItems.map((item, index) => (
        <div class="grid grid-rows md:grid-cols-[160px_1fr] font-spezia font-bold text-left rounded-lg hover:bg-gray-200 transition-colors duration-600 my-4 first:mt-0 last:mb-0 cursor-default">
          <div class={`px-5 py md:py-4 font-spezia text-md font-bold ${item.isBreak ? 'font-spezia font-bold' : ''}`}>
            {item.time}
          </div>
          <div class={`px-5 py md:py-4 ${item.isBreak ? 'font-spezia text-md font-bold' : ''}`}>
            {item.event}
          </div>
        </div>
      ))
    }
  </div>
</div>